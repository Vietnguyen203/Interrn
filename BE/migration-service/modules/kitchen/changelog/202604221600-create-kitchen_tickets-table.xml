<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="202604221600-create-kitchen_tickets-table" author="Vietnguyen203" labels="202604221600">
        <createTable tableName="kitchen_tickets">
            <column name="id" type="UUID">
                <constraints primaryKey="true"/>
            </column>
            <column name="order_items_id" type="UUID"/>
            <column name="order_id" type="UUID"/>
            <column name="quantity" type="INT"/>
            <column name="menu_items_name" type="VARCHAR(255)"/>
            <column name="status" type="SMALLINT"/>
            <column name="received_at" type="TIMESTAMP"/>
            <column name="completed_at" type="TIMESTAMP"/>
        </createTable>
        <rollback>
            <dropTable tableName="kitchen_tickets"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
