<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
       http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="202604221430-create-payments-tables" author="vietnguyen203" labels="202604221430">

        <createTable tableName="payments">
            <column name="id" type="UUID">
                <constraints primaryKey="true"/>
            </column>
            <column name="order_id" type="UUID"/>
            <column name="amount" type="DECIMAL(15,2)"/>
            <column name="method" type="VARCHAR(255)"/>
            <column name="status" type="SMALLINT"/>
            <column name="transaction_code" type="VARCHAR(255)"/>
            <column name="paid_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
        <rollback>
            <dropTable tableName="payments"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
